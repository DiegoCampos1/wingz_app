# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Dev-only: enable the django-silk profiler UI at /silk/ (set to 1 to turn on).
DJANGO_ENABLE_SILK=1

# Dev-only: load demo data on startup (idempotent; no-op if rides already exist).
DJANGO_SEED_DEMO=1

# PostgreSQL / PostGIS
POSTGRES_DB=wingz
POSTGRES_USER=wingz
POSTGRES_PASSWORD=wingz
POSTGRES_HOST=db
POSTGRES_PORT=5432
